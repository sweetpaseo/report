# Change both values before production deployment.
ADMIN_PASSWORD=admin123
CLIENT_PASSWORD=client123
SESSION_SECRET=replace-with-at-least-32-random-characters

# Persistent directory mounted from the VPS.
DATA_DIR=/app/data
MAX_UPLOAD_MB=20
NEXT_PUBLIC_APP_NAME=Website Health Report

# Deploy target (cPanel shared hosting via PuTTY plink/pscp). Local only.
DEPLOY_HOST=your.server.ip
DEPLOY_PORT=65002
DEPLOY_USER=your_cpanel_user
DEPLOY_PASS=your_cpanel_password
DEPLOY_DIR=/home/your_cpanel_user/domains/report.yourdomain.id
